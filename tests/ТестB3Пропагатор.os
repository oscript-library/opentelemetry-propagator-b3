Процедура Поля() Экспорт

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Поля();

    // Тогда
    Ожидаем.Что(Результат).ИмеетДлину(1);

КонецПроцедуры

// Формат инъекции: single-header

&Тест
Процедура ВнедрениеОдиночнымЗаголовком() Экспорт

    // Дано
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 1);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда - создаём пропагатор с single-header форматом
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Одиночный());
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - заголовок b3 установлен в формате {traceId}-{spanId}-{sampling}
    Ожидаем.Что(Носитель.Получить("b3")).Равно("0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-1");
    Ожидаем.Что(Носитель.Получить("X-B3-TraceId")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура ВнедрениеОдиночнымЗаголовкомБезСемплирования() Экспорт

    // Дано
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 0);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Одиночный());
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда
    Ожидаем.Что(Носитель.Получить("b3")).Равно("0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-0");

КонецПроцедуры

&Тест
Процедура ПоляМультиФормата() Экспорт

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Мульти());
    Результат = Пропагатор.Поля();

    // Тогда - 4 заголовка: TraceId, SpanId, Sampled, Flags (без ParentSpanId)
    КоличествоПолей = 4;
    Ожидаем.Что(Результат).ИмеетДлину(КоличествоПолей);
    Ожидаем.Что(Результат[0]).Равно("X-B3-TraceId");
    Ожидаем.Что(Результат[1]).Равно("X-B3-SpanId");
    Ожидаем.Что(Результат[2]).Равно("X-B3-Sampled");
    Ожидаем.Что(Результат[3]).Равно("X-B3-Flags");

КонецПроцедуры

&Тест
Процедура ПоляОдиночногоФормата() Экспорт

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Одиночный());
    Результат = Пропагатор.Поля();

    // Тогда - только заголовок b3
    Ожидаем.Что(Результат).ИмеетДлину(1);
    Ожидаем.Что(Результат[0]).Равно("b3");

КонецПроцедуры

&Тест
Процедура ФорматПоУмолчаниюОдиночныйЗаголовок() Экспорт

    // Когда - без параметра = single-header
    Пропагатор = Новый ОтелB3Пропагатор();
    Носитель = Новый Соответствие();
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 1);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);

    // Когда
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - single-header
    Ожидаем.Что(Носитель.Получить("b3")).Не_().Равно(Неопределено);
    Ожидаем.Что(Носитель.Получить("X-B3-TraceId")).Равно(Неопределено);

КонецПроцедуры

&Тест
Процедура РаундТрипОдиночныйФормат() Экспорт

    // Дано
    ИсходныйТрейсИд = "4bf92f3577b34da6a3ce929d0e0e4736";
    ИсходныйСпанИд = "00f067aa0ba902b7";
    КонтекстСпана = Новый ОтелКонтекстСпана(ИсходныйТрейсИд, ИсходныйСпанИд, 1);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    КонтекстВнедрения = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    Носитель = Новый Соответствие();

    // Когда - inject single, extract (auto-detects single)
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Одиночный());
    Пропагатор.Внедрить(КонтекстВнедрения, Носитель);
    Результат = Пропагатор.Извлечь(Новый Соответствие(), Носитель);

    // Тогда
    ВосстановленныйСпан = ОтелКонтекст.СпанИзКонтекста(Результат);
    ВосстановленныйКонтекст = ВосстановленныйСпан.КонтекстСпана();
    Ожидаем.Что(ВосстановленныйКонтекст.ИдТрассировки()).Равно(ИсходныйТрейсИд);
    Ожидаем.Что(ВосстановленныйКонтекст.ИдСпана()).Равно(ИсходныйСпанИд);
    Ожидаем.Что(ВосстановленныйКонтекст.ФлагиТрассировки()).Равно(1);

КонецПроцедуры
