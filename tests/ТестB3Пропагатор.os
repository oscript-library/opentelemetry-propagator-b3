&Тест
Процедура ИзвлечениеОдиночногоЗаголовкаТолькоОтказ() Экспорт

    // Дано - формат "0" означает deny (не семплирован), без traceId/spanId
    Носитель = Новый Соответствие();
    Носитель.Вставить("b3", "0");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - возвращается входной контекст (нет идентификаторов)
    Ожидаем.Что(Результат).Равно(ВходнойКонтекст);

КонецПроцедуры

// Извлечение: приоритет single header над multi-header

&Тест
Процедура ОдиночныйЗаголовокИмеетПриоритет() Экспорт

    // Дано - оба формата присутствуют, b3 имеет приоритет
    Носитель = Новый Соответствие();
    Носитель.Вставить("b3", "aaaabbbbccccddddeeee111122223333-1111222233334444-1");
    Носитель.Вставить("X-B3-TraceId", "0af7651916cd43dd8448eb211c80319c");
    Носитель.Вставить("X-B3-SpanId", "b7ad6b7169203331");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - используются значения из b3 single header
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    КонтекстСпана = Спан.КонтекстСпана();
    Ожидаем.Что(КонтекстСпана.ИдТрассировки()).Равно("aaaabbbbccccddddeeee111122223333");

КонецПроцедуры

