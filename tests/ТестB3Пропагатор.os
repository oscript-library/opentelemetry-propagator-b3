    Носитель.Вставить("X-B3-TraceId", "0af7651916cd43dd8448eb211c80319c");
    Носитель.Вставить("X-B3-SpanId", "b7ad6b7169203331");
    Носитель.Вставить("X-B3-Flags", "1");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - debug flag означает sampled
    Спан = ОтелКонтекст.СпанИзКонтекста(Результат);
    КонтекстСпана = Спан.КонтекстСпана();
    Ожидаем.Что(КонтекстСпана.ФлагиТрассировки()).Равно(1);

КонецПроцедуры

// Debug flag propagation

&Тест
Процедура ИзвлечениеМультиДебагСохраняетсяВКонтексте() Экспорт

    // Дано - X-B3-Flags: 1 означает debug
    Носитель = Новый Соответствие();
    Носитель.Вставить("X-B3-TraceId", "0af7651916cd43dd8448eb211c80319c");
    Носитель.Вставить("X-B3-SpanId", "b7ad6b7169203331");
    Носитель.Вставить("X-B3-Flags", "1");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - debug flag сохранен в контексте
    Ожидаем.Что(Результат.Получить(Пропагатор.КлючОтладки())).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ИзвлечениеОдиночногоДебагСохраняетсяВКонтексте() Экспорт

    // Дано - "d" в single-header означает debug
    Носитель = Новый Соответствие();
    Носитель.Вставить("b3", "0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-d");
    ВходнойКонтекст = Новый Соответствие();

    // Когда
    Пропагатор = Новый ОтелB3Пропагатор();
    Результат = Пропагатор.Извлечь(ВходнойКонтекст, Носитель);

    // Тогда - debug flag сохранен в контексте
    Ожидаем.Что(Результат.Получить(Пропагатор.КлючОтладки())).Равно(Истина);

КонецПроцедуры

&Тест
Процедура ВнедрениеМультиДебагПишетФлаг() Экспорт

    // Дано - контекст с debug flag
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Мульти());
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 1);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    // Добавляем debug flag в контекст
    МутабельныйКонтекст = Новый Соответствие();
    Для Каждого КлючИЗначение Из Контекст Цикл
        МутабельныйКонтекст.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
    КонецЦикла;
    МутабельныйКонтекст.Вставить(Пропагатор.КлючОтладки(), Истина);
    Контекст = Новый ФиксированноеСоответствие(МутабельныйКонтекст);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - X-B3-Flags установлен, X-B3-Sampled = 1
    Ожидаем.Что(Носитель.Получить("X-B3-Flags")).Равно("1");
    Ожидаем.Что(Носитель.Получить("X-B3-Sampled")).Равно("1");

КонецПроцедуры

&Тест
Процедура ВнедрениеОдиночнымДебагПишетD() Экспорт

    // Дано - контекст с debug flag
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Одиночный());
    КонтекстСпана = Новый ОтелКонтекстСпана("0af7651916cd43dd8448eb211c80319c", "b7ad6b7169203331", 1);
    Спан = Новый ОтелНоопСпан(КонтекстСпана);
    Контекст = ОтелКонтекст.КонтекстСоСпаном(Новый Соответствие(), Спан);
    МутабельныйКонтекст = Новый Соответствие();
    Для Каждого КлючИЗначение Из Контекст Цикл
        МутабельныйКонтекст.Вставить(КлючИЗначение.Ключ, КлючИЗначение.Значение);
    КонецЦикла;
    МутабельныйКонтекст.Вставить(Пропагатор.КлючОтладки(), Истина);
    Контекст = Новый ФиксированноеСоответствие(МутабельныйКонтекст);
    Носитель = Новый Соответствие();

    // Когда
    Пропагатор.Внедрить(Контекст, Носитель);

    // Тогда - single-header содержит "d" вместо "1"
    Ожидаем.Что(Носитель.Получить("b3")).Равно("0af7651916cd43dd8448eb211c80319c-b7ad6b7169203331-d");

КонецПроцедуры

&Тест
Процедура РаундТрипДебагМульти() Экспорт

    // Дано - извлекаем с debug, внедряем обратно
    НосительВходной = Новый Соответствие();
    НосительВходной.Вставить("X-B3-TraceId", "0af7651916cd43dd8448eb211c80319c");
    НосительВходной.Вставить("X-B3-SpanId", "b7ad6b7169203331");
    НосительВходной.Вставить("X-B3-Flags", "1");

    // Когда - extract → inject
    Пропагатор = Новый ОтелB3Пропагатор(ОтелФорматB3.Мульти());
    Контекст = Пропагатор.Извлечь(Новый Соответствие(), НосительВходной);
    НосительВыходной = Новый Соответствие();
    Пропагатор.Внедрить(Контекст, НосительВыходной);

    // Тогда - debug flag сохранился
    Ожидаем.Что(НосительВыходной.Получить("X-B3-Flags")).Равно("1");
    Ожидаем.Что(НосительВыходной.Получить("X-B3-Sampled")).Равно("1");

КонецПроцедуры

